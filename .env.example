# Copy this file to .env and fill in the values.
# Lines starting with # are comments.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://geoobras:geoobras@localhost:5432/geoobras

# ---------------------------------------------------------------------------
# ObrasGov.br
# ---------------------------------------------------------------------------
OBRASGOV_BASE_URL=https://api.obrasgov.gestao.gov.br/obrasgov/api
OBRASGOV_UF=RJ
OBRASGOV_PAGE_SIZE=20
OBRASGOV_MUNICIPIO_ALVO=Macaé
OBRASGOV_MAX_PAGES=5

# ---------------------------------------------------------------------------
# TCE-RJ
# ---------------------------------------------------------------------------
TCERJ_BASE_URL=https://dados.tcerj.tc.br/api/v1
TCERJ_PAGE_SIZE=5
TCERJ_MAX_PAGES=5

# ---------------------------------------------------------------------------
# Convênios CSV
# ---------------------------------------------------------------------------
CONVENIOS_DIR=data/input/macae_convenios

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
HTTP_TIMEOUT=90
HTTP_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# LLM (insights endpoint — app boots normally when this is empty)
# ---------------------------------------------------------------------------
LLM_API_KEY=
LLM_MODEL=llama3-70b-8192
LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions
LLM_MAX_TOKENS=1024
